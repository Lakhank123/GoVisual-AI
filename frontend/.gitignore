# ======================================================
# GoVisual AI - Git Ignore
# ======================================================

# ------------------------------------------------------
# Environment Variables (NEVER COMMIT)
# ------------------------------------------------------
.env
.env.*
!.env.example

# ------------------------------------------------------
# Node.js / Next.js
# ------------------------------------------------------
node_modules/
.next/
out/
dist/
build/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------------------------------
# Python
# ------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version

.venv/
venv/
env/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml

# ------------------------------------------------------
# IDE
# ------------------------------------------------------
.vscode/
.idea/

# ------------------------------------------------------
# Operating System
# ------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------
# Logs
# ------------------------------------------------------
logs/
*.log

# ------------------------------------------------------
# Build Artifacts
# ------------------------------------------------------
*.tsbuildinfo

# ------------------------------------------------------
# Generated Media
# ------------------------------------------------------
backend/generated_images/*
!backend/generated_images/.gitkeep

backend/generated_videos/*
!backend/generated_videos/.gitkeep

backend/debug_images/*
!backend/debug_images/.gitkeep

backend/minisites/*
!backend/minisites/.gitkeep

# ------------------------------------------------------
# Temporary Files
# ------------------------------------------------------
backend/tmp_*
backend/test_*
*.tmp
*.bak
*.swp

# ------------------------------------------------------
# Machine Learning Models
# (Large model weights should NOT be committed)
# ------------------------------------------------------
backend/ml_model/model.safetensors
backend/ml_model/training_args.bin

# ------------------------------------------------------
# HuggingFace / Transformers Cache
# ------------------------------------------------------
.cache/
huggingface/
hf_cache/

# ------------------------------------------------------
# Archive
# Keep project history but ignore huge datasets
# ------------------------------------------------------
archive/*.csv
archive/**/*.csv

# ------------------------------------------------------
# Local Databases
# ------------------------------------------------------
*.sqlite3
*.db

# ------------------------------------------------------
# Vercel
# ------------------------------------------------------
.vercel/

# ------------------------------------------------------
# Docker
# ------------------------------------------------------
docker-compose.override.yml

# ------------------------------------------------------
# Misc
# ------------------------------------------------------
*.pem
*.key
*.crt