# GoVisual AI — Environment Variables
# Copy this file to .env and fill in your actual keys

# Google Places API (for brand lookup)
GOOGLE_PLACES_API_KEY=

# Gemini API (for image generation)
GEMINI_API_KEY=

# OpenAI API (for image generation, photoshoot, brandbook, and miniwebsite)
OPENAI_API_KEY=

# HuggingFace API token for FLUX.1-schnell fallback image generation
HF_API_TOKEN=

# T5 Model path (local directory or HuggingFace repo)
T5_MODEL_PATH=./ml_model

# Cloudinary (for image hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Set to "true" to save images locally instead of Cloudinary
USE_LOCAL_STORAGE=true

# Watermark image path
WATERMARK_PATH=./watermark.png

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
